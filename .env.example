# Copy to .env for local dev. Set these in Vercel → Environment Variables.
# Use your external Supabase project (jacbalsongvqvaqlfsbx).

SUPABASE_PROJECT_ID=jacbalsongvqvaqlfsbx
SUPABASE_URL=https://jacbalsongvqvaqlfsbx.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

VITE_SUPABASE_PROJECT_ID=jacbalsongvqvaqlfsbx
VITE_SUPABASE_URL=https://jacbalsongvqvaqlfsbx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Comma-separated emails allowed to access /admin/curation (when admin auth is enabled)
VITE_ADMIN_EMAILS=you@example.com